# Copy this file to .env and fill in values
# Never commit .env to git

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=stocks
DB_USER=stocks
DB_PASSWORD=changeme
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Application
LOG_LEVEL=INFO
ENVIRONMENT=development
MAX_INGEST_AGE_HOURS=25

# External API keys — obtain from provider dashboards
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=
# ENTSO-E day-ahead electricity prices: register at https://transparency.entsoe.eu
# then go to Settings → Web API Security Token to generate one. Required for
# the daily energy ingest (region FI/SE3/SE4/EE/LT/LV).
ENTSOE_API_TOKEN=

# API authentication. MASTER_API_KEY is for local dev / bootstrap and bypasses
# the api_key DB table when set. Production keys are issued via:
#     python -m app.tools.create_api_key --name <label>
# Leave empty to disable the master path entirely.
MASTER_API_KEY=

# Grafana (local dev only — default admin/admin)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
